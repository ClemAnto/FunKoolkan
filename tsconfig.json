{
  /* Base configuration. Do not edit this field. */
  "extends": "./temp/tsconfig.cocos.json",

  /* Add your custom configuration here. */
  "compilerOptions": {
    "strict": true,
    /* The Cocos-generated base (temp/) still uses moduleResolution "node" (node10),
       deprecated in TS 6. Override with the modern pair — IDE/typecheck only, the
       Cocos build pipeline compiles with its own settings. */
    "module": "esnext",
    "moduleResolution": "bundler",
    /* Object.values & co.: every browser the game targets supports ES2017. */
    "lib": ["ES2017", "DOM"]
  }
}
